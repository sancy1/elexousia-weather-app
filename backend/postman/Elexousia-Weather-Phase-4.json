{
	"info": {
		"_postman_id": "elexousia-weather-phase-4",
		"name": "Elexousia Weather - Phase 4",
		"description": "Phase 4 Personalization endpoints: Saved Locations, Conversations, Search, Notifications",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8000/api",
			"type": "string"
		}
	],
	"item": [
		{
			"name": "Saved Locations",
			"item": [
				{
					"name": "GET Saved Locations",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/saved-locations",
							"host": ["{{base_url}}"],
							"path": ["saved-locations"]
						},
						"description": "Get user's saved locations ordered by display_order"
					},
					"response": []
				},
				{
					"name": "POST Saved Location",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"city_name\": \"Abuja\",\n  \"country_code\": \"NG\",\n  \"label\": \"Home\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/saved-locations",
							"host": ["{{base_url}}"],
							"path": ["saved-locations"]
						},
						"description": "Add a new saved location"
					},
					"response": []
				},
				{
					"name": "PATCH Saved Location",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"label\": \"Updated Label\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/saved-locations/1",
							"host": ["{{base_url}}"],
							"path": ["saved-locations", "1"]
						},
						"description": "Update label or display_order for a saved location"
					},
					"response": []
				},
				{
					"name": "PATCH Set Default Location",
					"request": {
						"method": "PATCH",
						"header": [],
						"url": {
							"raw": "{{base_url}}/saved-locations/1/default",
							"host": ["{{base_url}}"],
							"path": ["saved-locations", "1", "default"]
						},
						"description": "Set this location as default (shown on load)"
					},
					"response": []
				},
				{
					"name": "DELETE Saved Location",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/saved-locations/1",
							"host": ["{{base_url}}"],
							"path": ["saved-locations", "1"]
						},
						"description": "Remove a saved location"
					},
					"response": []
				}
			]
		},
		{
			"name": "Conversations",
			"item": [
				{
					"name": "GET Conversations",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/conversations?page=1&per_page=20",
							"host": ["{{base_url}}"],
							"path": ["conversations"],
							"query": [
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "per_page",
									"value": "20"
								}
							]
						},
						"description": "Get user's conversation list for sidebar (paginated)"
					},
					"response": []
				},
				{
					"name": "POST Conversation",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"session_id\": \"session-123\",\n  \"title\": \"Lagos weather today\",\n  \"city_name\": \"Lagos\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/conversations",
							"host": ["{{base_url}}"],
							"path": ["conversations"]
						},
						"description": "Create new conversation, returns session_id"
					},
					"response": []
				},
				{
					"name": "GET Conversation by ID",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/conversations/1",
							"host": ["{{base_url}}"],
							"path": ["conversations", "1"]
						},
						"description": "Get full conversation with all messages"
					},
					"response": []
				},
				{
					"name": "PATCH Conversation",
					"request": {
						"method": "PATCH",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"title\": \"Updated Title\"\n}"
						},
						"url": {
							"raw": "{{base_url}}/conversations/1",
							"host": ["{{base_url}}"],
							"path": ["conversations", "1"]
						},
						"description": "Update title or archive a conversation"
					},
					"response": []
				},
				{
					"name": "DELETE Conversation",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/conversations/1",
							"host": ["{{base_url}}"],
							"path": ["conversations", "1"]
						},
						"description": "Permanently delete conversation and all messages"
					},
					"response": []
				},
				{
					"name": "GET Conversation Messages",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/conversations/1/messages?page=1&per_page=50",
							"host": ["{{base_url}}"],
							"path": ["conversations", "1", "messages"],
							"query": [
								{
									"key": "page",
									"value": "1"
								},
								{
									"key": "per_page",
									"value": "50"
								}
							]
						},
						"description": "Returns paginated messages for a conversation"
					},
					"response": []
				}
			]
		},
		{
			"name": "Search",
			"item": [
				{
					"name": "GET Search",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/search?q=Lagos&limit=20",
							"host": ["{{base_url}}"],
							"path": ["search"],
							"query": [
								{
									"key": "q",
									"value": "Lagos"
								},
								{
									"key": "limit",
									"value": "20"
								}
							]
						},
						"description": "Searches all indexed content for user (conversations, saved locations)"
					},
					"response": []
				},
				{
					"name": "GET Search Cities",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/search/cities?q=Par&limit=10",
							"host": ["{{base_url}}"],
							"path": ["search", "cities"],
							"query": [
								{
									"key": "q",
									"value": "Par"
								},
								{
									"key": "limit",
									"value": "10"
								}
							]
						},
						"description": "Searches global cities table for city picker (no auth required)"
					},
					"response": []
				}
			]
		},
		{
			"name": "Notifications",
			"item": [
				{
					"name": "GET Notifications",
					"request": {
						"method": "GET",
						"header": [],
						"url": {
							"raw": "{{base_url}}/notifications",
							"host": ["{{base_url}}"],
							"path": ["notifications"]
						},
						"description": "Returns unread notifications count + list for bell icon"
					},
					"response": []
				},
				{
					"name": "PATCH Mark as Read",
					"request": {
						"method": "PATCH",
						"header": [],
						"url": {
							"raw": "{{base_url}}/notifications/1/read",
							"host": ["{{base_url}}"],
							"path": ["notifications", "1", "read"]
						},
						"description": "Marks a notification as read"
					},
					"response": []
				},
				{
					"name": "PATCH Mark All as Read",
					"request": {
						"method": "PATCH",
						"header": [],
						"url": {
							"raw": "{{base_url}}/notifications/read-all",
							"host": ["{{base_url}}"],
							"path": ["notifications", "read-all"]
						},
						"description": "Marks all notifications as read"
					},
					"response": []
				},
				{
					"name": "DELETE Notification",
					"request": {
						"method": "DELETE",
						"header": [],
						"url": {
							"raw": "{{base_url}}/notifications/1",
							"host": ["{{base_url}}"],
							"path": ["notifications", "1"]
						},
						"description": "Deletes a notification"
					},
					"response": []
				},
				{
					"name": "POST Check Notifications",
					"request": {
						"method": "POST",
						"header": [],
						"url": {
							"raw": "{{base_url}}/notifications/check",
							"host": ["{{base_url}}"],
							"path": ["notifications", "check"]
						},
						"description": "Internal/cron endpoint: Checks saved locations and creates alerts if needed"
					},
					"response": []
				}
			]
		}
	]
}

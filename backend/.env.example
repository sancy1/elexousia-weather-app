# ──────────────────────────────────────────────────────────────
# Elexousia Weather API - Environment Configuration
# ──────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────
APP_NAME="Elexousia Weather API"
APP_VERSION="1.0.0"
DEBUG=true
ENVIRONMENT=development

HOST=0.0.0.0
PORT=8000

# ── CORS (comma-separated) ───────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Database (Neon PostgreSQL) ───────────────────────────────
DATABASE_URL=postgresql://neondb_owner:npg_3OSz8TJkAvCH@ep-curly-mode-amz3qy3g-pooler.c-5.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# ── LLM Provider (ollama, groq, or gemini) ───────────────────
LLM_PROVIDER=ollama

# Ollama (local, free)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Groq (optional - fast cloud inference)
GROQ_API_KEY=
GROQ_MODEL=mixtral-8x7b-32768

# Gemini (optional - Google's LLM)
GOOGLE_API_KEY=AIzaSyALqWvoSfHkCk4F_29vP7eMqpaCqoSnEZI
GEMINI_MODEL=gemini-1.5-flash

# ── Embeddings ───────────────────────────────────────────────
EMBED_MODEL=mxbai-embed-large
EMBED_DIM=1024

# ── Weather API ──────────────────────────────────────────────
WEATHER_API_KEY=1057ce1c26da4616b62103935252103
WEATHER_API_BASE=https://api.weatherapi.com/v1

# ── OAuth (Google & GitHub) ─────────────────────────────────
# Optional - OAuth providers for authentication
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# React app URL (OAuth redirect target). When this is https (e.g. Vercel), the API
# sets session_token with SameSite=None; Secure so /api/auth/me works from the browser.
FRONTEND_URL=http://localhost:5173

# ── Security ─────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=elexousia_weather_secret_key_2025_change_this_in_production_32_chars_min
SESSION_EXPIRY_DAYS=1

# ── Rate Limiting (requests per minute) ─────────────────────
RATE_LIMIT_CHAT=30
RATE_LIMIT_WEATHER=100
RATE_LIMIT_AUTH=10
RATE_LIMIT_DEFAULT=200

# ── Observability (optional) ────────────────────────────────
SENTRY_DSN=
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=elexousia-weather

# ── Cache Configuration ─────────────────────────────────────
WEATHER_CACHE_TTL_SECONDS=600
MEMORY_CACHE_MAX_SIZE=1000

# ── Session Cookie ──────────────────────────────────────────
COOKIE_NAME=elexousia_session
COOKIE_SECURE=false
COOKIE_HTTPONLY=true
COOKIE_SAMESITE=lax

# ── Production Overrides (use these in production) ───────────
# For production deployment, override the above with:
# DEBUG=false
# ENVIRONMENT=production
# ALLOWED_ORIGINS=https://elexousia-weather.com,https://www.elexousia-weather.com
# COOKIE_SECURE=true
# LLM_PROVIDER=groq
# DATABASE_URL=postgresql://user:password@host:port/dbname?sslmode=require
# SECRET_KEY=your_64_char_random_string